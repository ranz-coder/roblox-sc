local StarterGui = game:GetService("StarterGui")
local function sendSystemNotification(title, msg, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = msg,
            Duration = duration or 5,
            Button1 = "OK"
        })
    end)
end
local games = {
    [93978595733734] = "https://raw.githubusercontent.com/ranz-coder/roblox-sc/refs/heads/script/LaPer-UNI.lua", -- Violence District
}

local fallbackUniversalURL = "https://raw.githubusercontent.com/ranz-coder/roblox-sc/refs/heads/script/LaPer-UNI.lua"

local currentPlaceId = game.PlaceId
local targetScriptURL = games[currentPlaceId]

if targetScriptURL then
    sendSystemNotification("LaperGank System", "Map Spesifik Terdeteksi! Memuat Hub...", 3)
else
    sendSystemNotification("LaperGank System", "Map Universal! Menggunakan LaPer-UNI...", 3)
    targetScriptURL = fallbackUniversalURL
end

if targetScriptURL then
    local success, scriptContent = pcall(function()
        return game:HttpGet(targetScriptURL)
    end)
    
    if success and scriptContent then
        local executeScript, err = loadstring(scriptContent)
        if executeScript then
            pcall(executeScript)
            sendSystemNotification("Laper Gank Panel", "LaPer-HUB Berhasil Dijalankan!", 3)
        else
            sendSystemNotification("Loader Error", "Gagal memproses kode: " .. tostring(err), 5)
        end
    else
        sendSystemNotification("Connection Error", "Gagal mengambil data dari repositori ranz-coder!", 5)
    end
end

-- LOGIKA PLAYER LIST & SEARCH BAR (Kanan)
local function updatePlayerList(query)
	query = query and string.lower(query) or ""
	for _, child in ipairs(playerScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer then
			local pNameLower = string.lower(player.Name)
			if query == "" or string.sub(pNameLower, 1, #query) == query then
				local btn = Instance.new("TextButton")
				btn.Size = UDim2.new(0.95, 0, 0, 32)
				btn.BackgroundColor3 = Color3.fromRGB(26, 26, 32)
				btn.BackgroundTransparency = 0.3
				btn.Text = "  " .. player.Name
				btn.TextColor3 = Color3.fromRGB(255, 255, 255)
				btn.Font = Enum.Font.GothamBold
				btn.TextSize = 11
				btn.TextXAlignment = Enum.TextXAlignment.Left
				btn.Parent = playerScroll
				Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
				Instance.new("UIStroke", btn).Color = Color3.fromRGB(138, 43, 226)
				btn.Activated:Connect(function()
					selectedPlayer = player targetDisplayBtn.Text = "Target: " .. player.Name
				end)
			end
		end
	end
end

RunService.Heartbeat:Connect(function(deltaTime)
	pcall(function()
		local char = localPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChild("Humanoid")
		local camera = workspace.CurrentCamera
		
		-- GOD MODE (AUTO HEAL)
		if godModeEnabled and hum and hum.Health < hum.MaxHealth then hum.Health = hum.MaxHealth end
		
		-- DESYNC VELOCITY RESET (MPP)
		if flags.Desync and char and hrp and desyncPos then
			pcall(function() hrp.Velocity = Vector3.new(0, 0, 0) end)
		end
		
		-- AUTO AIM (SMOOTH LERPING)
		if autoAimEnabled and camera then
			local viewportCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
			fovCircle.Position = UDim2.new(0, viewportCenter.X, 0, viewportCenter.Y)
			local closestPlayer, shortestDistance = nil, fovRadius
			
			for _, player in ipairs(Players:GetPlayers()) do
				if player ~= localPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
					local targetHrp = player.Character.HumanoidRootPart
					local targetHum = player.Character:FindFirstChild("Humanoid")
					if targetHum and targetHum.Health > 0 then
						local screenPoint, onScreen = camera:WorldToViewportPoint(targetHrp.Position)
						if onScreen then
							local screenPos = Vector2.new(screenPoint.X, screenPoint.Y)
							local distance = (viewportCenter - screenPos).Magnitude
							if distance < shortestDistance then
								closestPlayer = player
								shortestDistance = distance
							end
						end
					end
				end
			end
			if closestPlayer then
				local targetPos = closestPlayer.Character.HumanoidRootPart.Position
				local targetCFrame = CFrame.new(camera.CFrame.Position, targetPos)
				camera.CFrame = camera.CFrame:Lerp(targetCFrame, 0.15) 
			end
		end
		
		-- MOVEMENT BYPASS & MOONWALK
		if hrp and hum then
			if moonwalkEnabled then
				hum.AutoRotate = false
				if hum.MoveDirection.Magnitude > 0 then hrp.CFrame = CFrame.new(hrp.Position, hrp.Position - hum.MoveDirection) end
			else
				if hum.AutoRotate == false then hum.AutoRotate = true end
			end
			
			if speedSettings.Enabled and speedSettings.TargetSpeed > 16 and not flySettings.Enabled then
				if hum.MoveDirection.Magnitude > 0 then hrp.CFrame = hrp.CFrame + (hum.MoveDirection * ((speedSettings.TargetSpeed - 16) * deltaTime)) end
			elseif hum.WalkSpeed ~= 16 and not speedSettings.Enabled and not flySettings.Enabled then hum.WalkSpeed = 16 end
			if jumpSettings.Enabled then hum.UseJumpPower = true if hum.JumpPower ~= jumpSettings.TargetPower then hum.JumpPower = jumpSettings.TargetPower end end
			
			if wallhopEnabled then
				if hum.FloorMaterial == Enum.Material.Air and hum.MoveDirection.Magnitude > 0 then
					local origin = hrp.Position local direction = hum.MoveDirection * 2
					local rayParams = RaycastParams.new() rayParams.FilterPlayers = {char} rayParams.FilterType = Enum.RaycastFilterType.Exclude
					if workspace:Raycast(origin, direction, rayParams) then hrp.Velocity = Vector3.new(hrp.Velocity.X, jumpSettings.TargetPower > 50 and jumpSettings.TargetPower or 50, hrp.Velocity.Z) end
				end
			end
		end
	end)
end)

